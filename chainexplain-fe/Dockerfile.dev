FROM node:22-alpine

WORKDIR /app

# Copy dependency files
COPY package.json package-lock.json ./

# Install dependencies
RUN npm install

# Copy source code
COPY . .

# Expose Vite dev server port
EXPOSE 5173

# Start Vite server, bound to all network interfaces so it can be accessed outside the container
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
